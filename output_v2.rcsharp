fn insert_symbol(data: &i8, len: i32, symbols: &vector::Vec<string::String>){
	for i in 0 as u32..symbols.length{
	if symbols.array[i].len  len {
		continue
	}
	if mem::compare(data, symbols.array[i].data, len as i64)  0 {
	return i as u16
	}
	}
	let symbol_id : u16 = symbols.length as u16
	vector::push::<string::String>(symbols, string::from_data(data, len))
	return symbol_id
}
fn handle_number(data: &i8, start: u32, end: u32, tokens: &vector::Vec<TokenData>, symbols: &vector::Vec<string::String>){
	let symbol_id : u16 = insert_symbol(data  start, end  start as i32, symbols)
	let temp : TokenData = TokenData::{token_type: TokenType::Integer, symbol_id: symbol_id, file_offset: start}
	vector::push::<TokenData>(tokens, temp)
}
fn handle_decimal_number(data: &i8, start: u32, end: u32, tokens: &vector::Vec<TokenData>, symbols: &vector::Vec<string::String>){
	let symbol_id : u16 = insert_symbol(data  start, end  start as i32, symbols)
	let temp : TokenData = TokenData::{token_type: TokenType::Decimal, symbol_id: symbol_id, file_offset: start}
	vector::push::<TokenData>(tokens, temp)
}
fn handle_string(data: &i8, start: u32, end: u32, tokens: &vector::Vec<TokenData>, symbols: &vector::Vec<string::String>){
	let len : i32 = end  start as i32  2
	let start_ptr : &i8 = data  start  1
	let stack_buffer : &i8 = stalloc::<i8>(len)
	let index : u32 = start  1
	let write_head : u32 = 0
	while index  end  1{
	let current_char : i8 = data[index]
	if current_char  '\\' {
	let next_char : i8 = data[index  1]
	let return_char : i8
	if next_char  '\\' {
	return_char  '\\'
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '\'' {
	return_char  '\''
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '' {
	return_char  11
	} else {
	if next_char  '' {
	return_char  12
	} else {
	if next_char  '' {
	return_char  0
	} else {
	let start_ptr : &i8 = data  start  1
	console::println_i64(next_char as i64)
	console::writeln(start_ptr, len)
	process::throw("Invalid escape character!")
	}
	}
	}
	}
	}
	}
	}
	}
	}
	stack_buffer[write_head]  return_char
	write_head  write_head  1
	index  index  2
		continue
	}
	stack_buffer[write_head]  current_char
	write_head  write_head  1
	index  index  1
	}
	let symbol_id : u16 = insert_symbol(start_ptr, len, symbols)
	let temp : TokenData = TokenData::{token_type: TokenType::String, symbol_id: symbol_id, file_offset: start}
	vector::push::<TokenData>(tokens, temp)
}
fn handle_char(data: &i8, start: u32, end: u32, tokens: &vector::Vec<TokenData>, symbols: &vector::Vec<string::String>){
	let len : i32 = end  start as i32  2
	let start_ptr : &i8 = data  start  1
	let start_char : i8 = *start_ptr
	if start_char  '\\' {
	let next_char : i8 = *start_ptr  1
	let return_char : u16
	if next_char  '\\' {
	return_char  '\\'
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '' {
	return_char  ''
	} else {
	if next_char  '\'' {
	return_char  '\''
	} else {
	if next_char  '' {
	return_char  11
	} else {
