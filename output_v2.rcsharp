enum BinaryOp{
	Add
	Subtract
	Multiply
	Divide
	Modulo
	Assign
	Equals
	NotEqual
	Less
	LessEqual
	Greater
	GreaterEqual
	And
	Or
	BitAnd
	BitOr
	BitXor
	ShiftLeft
	ShiftRight
}
enum UnaryOp{
	Negate
	Not
	Deref
	Pointer
	BitFlip
}
enum ExpressionType{
	Integer
	Char
	Decimal
	Name
	StringConst
	Type
	BinaryOp
	UnaryOp
	Cast
	MemberAccess
	StaticAccess
	NameWithGenerics
	Call
	Index
	Array
	StructInit
	Range
	Boolean
	NullPtr
}
fn is_prefix_operator(token: TokenType){
	return token  TokenType::Minus  token  TokenType::Plus  token  TokenType::LogicNot  token  TokenType::BitNot  token  TokenType::BitAnd  token  TokenType::Multiply
}
fn precedence(token: TokenType){
	if token  TokenType::Equal  token  TokenType::RangeDots  token  TokenType::RangeDotsInclusive {
	return 1
	}
	if token  TokenType::LogicOr {
	return 2
	}
	if token  TokenType::LogicAnd {
	return 3
	}
	if token  TokenType::BitOr {
	return 4
	}
	if token  TokenType::BitXor {
	return 5
	}
	if token  TokenType::BitAnd {
	return 6
	}
	if token  TokenType::LogicEqual  token  TokenType::LogicNotEqual {
	return 7
	}
	if token  TokenType::LogicLess  token  TokenType::LogicLessEqual  token  TokenType::LogicGreater  token  TokenType::LogicGreaterEqual {
	return 8
	}
	if token  TokenType::BitShiftL  token  TokenType::BitShiftR {
	return 9
	}
	if token  TokenType::Plus  token  TokenType::Minus {
	return 10
	}
	if token  TokenType::Multiply  token  TokenType::Divide  token  TokenType::Modulo {
	return 11
	}
	if token  TokenType::KeywordAs {
	return 12
	}
	if token  TokenType::LogicNot  token  TokenType::BitNot {
	return 13
	}
	if token  TokenType::LParen  token  TokenType::LSquareBrace  token  TokenType::Dot  token  TokenType::DoubleColon {
	return 14
	}
	return 0
}
fn get_unary_op(token: TokenType){
	if token  TokenType::Minus {
	return UnaryOp::Negate
	}
	if token  TokenType::LogicNot {
	return UnaryOp::Not
	}
	if token  TokenType::Multiply {
	return UnaryOp::Deref
	}
	if token  TokenType::BitAnd {
	return UnaryOp::Pointer
	}
	if token  TokenType::BitNot {
	return UnaryOp::BitFlip
	}
	process::throw("Invalid unary operator")
	return UnaryOp::Negate
}
fn get_binary_op(token: TokenType){
	if token  TokenType::Plus {
	return BinaryOp::Add
	}
	if token  TokenType::Minus {
	return BinaryOp::Subtract
	}
	if token  TokenType::Multiply {
	return BinaryOp::Multiply
	}
	if token  TokenType::Divide {
	return BinaryOp::Divide
	}
	if token  TokenType::Modulo {
	return BinaryOp::Modulo
	}
	if token  TokenType::Equal {
	return BinaryOp::Assign
	}
	if token  TokenType::LogicEqual {
	return BinaryOp::Equals
	}
	if token  TokenType::LogicNotEqual {
	return BinaryOp::NotEqual
	}
	if token  TokenType::LogicLess {
	return BinaryOp::Less
	}
	if token  TokenType::LogicLessEqual {
	return BinaryOp::LessEqual
	}
	if token  TokenType::LogicGreater {
	return BinaryOp::Greater
	}
	if token  TokenType::LogicGreaterEqual {
	return BinaryOp::GreaterEqual
	}
	if token  TokenType::LogicAnd {
	return BinaryOp::And
	}
	if token  TokenType::LogicOr {
	return BinaryOp::Or
	}
	if token  TokenType::BitAnd {
	return BinaryOp::BitAnd
	}
	if token  TokenType::BitOr {
	return BinaryOp::BitOr
	}
	if token  TokenType::BitXor {
	return BinaryOp::BitXor
	}
	if token  TokenType::BitShiftL {
	return BinaryOp::ShiftLeft
	}
	if token  TokenType::BitShiftR {
	return BinaryOp::ShiftRight
	}
	process::throw("Invalid binary operator")
	return BinaryOp::Add
}
fn parse_expression_internal(tokens: &TokenData, index: &u32, len: u32, min_precedence: u8){
	if *index  len {
	process::throw("Unexpected end of tokens in expression")
	}
	let expr : Expression
	let tt : TokenType = tokens[*index].token_type
	if tt  TokenType::Integer {
	let int_expr : &IntegerExpr = mem::malloc(size_of::<IntegerExpr>()) as &IntegerExpr
	int_expr.idx  tokens[*index].symbol_id
	expr.type  ExpressionType::Integer
	expr.val  bitcast::<&void>(int_expr)
	*index  *index  1
	} else {
	if tt  TokenType::Char {
	let char_expr : &CharExpr = mem::malloc(size_of::<CharExpr>()) as &CharExpr
	char_expr.val  tokens[*index].symbol_id
	expr.type  ExpressionType::Char
	expr.val  bitcast::<&void>(char_expr)
	*index  *index  1
	} else {
	if tt  TokenType::Decimal {
	let dec_expr : &DecimalExpr = mem::malloc(size_of::<DecimalExpr>()) as &DecimalExpr
	dec_expr.idx  tokens[*index].symbol_id
	expr.type  ExpressionType::Decimal
	expr.val  bitcast::<&void>(dec_expr)
	*index  *index  1
	} else {
	if tt  TokenType::Name {
	let name_expr : &NameExpr = mem::malloc(size_of::<NameExpr>()) as &NameExpr
	name_expr.idx  tokens[*index].symbol_id
	expr.type  ExpressionType::Name
	expr.val  bitcast::<&void>(name_expr)
	*index  *index  1
	} else {
	if tt  TokenType::String {
	let str_expr : &StringConstExpr = mem::malloc(size_of::<StringConstExpr>()) as &StringConstExpr
	str_expr.idx  tokens[*index].symbol_id
	expr.type  ExpressionType::StringConst
	expr.val  bitcast::<&void>(str_expr)
	*index  *index  1
	} else {
	if tt  TokenType::KeywordTrue {
	let bol_expr : &BoolExpr = mem::malloc(size_of::<BoolExpr>()) as &BoolExpr
	bol_expr.val  true
	expr.type  ExpressionType::Boolean
	expr.val  bitcast::<&void>(bol_expr)
	*index  *index  1
	} else {
	if tt  TokenType::KeywordFalse {
	let bol_expr : &BoolExpr = mem::malloc(size_of::<BoolExpr>()) as &BoolExpr
	bol_expr.val  false
	expr.type  ExpressionType::Boolean
	expr.val  bitcast::<&void>(bol_expr)
	*index  *index  1
	} else {
	if tt  TokenType::LParen {
	*index  *index  1
	expr  parse_expression_internal(tokens, index, len, 0)
	expect(tokens, index, len, TokenType::RParen, "Expected ')' after parenthesized expression")
	} else {
	if tt  TokenType::LSquareBrace {
	*index  *index  1
