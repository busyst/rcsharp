	let type_name_idx : u16 = path.data[path.len  1]
	path.len  path.len  1
	let rval : Type
	if *index  len  token_array[*index].token_type  TokenType::LogicLess {
	*index  *index  1
	let gen_args : vector::Vec<Type> = parse_generic_args(token_array, index, len)
