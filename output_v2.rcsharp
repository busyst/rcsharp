	if token_array[*index].token_type  TokenType::BitAnd {
	pointer_depth  pointer_depth  1
	*index  *index  1
	} else {
	if token_array[*index].token_type  TokenType::LogicAnd {
	pointer_depth  pointer_depth  2
	*index  *index  1
	} else {
		break
