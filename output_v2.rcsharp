fn println_u64(n: u64){
	let buffer : &i8 = stalloc::<i8>(22)
	let i : i32 = 20
	if n  0 {
	write("0\n", 2)
	return
	}
	let mut_n : u64 = n
	do{
	buffer[i]  mut_n  10 as i8  ''
	mut_n  mut_n  10
	i  i  1
	}while mut_n  0;
	buffer[21]  ''
