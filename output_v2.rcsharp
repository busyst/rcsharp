fn RegisterClassA(lpWndClass: &WNDCLASSEXA)
fn CreateWindowExA(dwExStyle: u32, lpClassName: &i8, lpWindowName: &i8, dwStyle: u32, x: i32, y: i32, nWidth: i32, nHeight: i32, hWndParent: &void, hMenu: &void, hInstance: &void, lpParam: &void)
fn DefWindowProcA(hWnd: &void, Msg: u32, wParam: u64, lParam: u64)
fn GetMessageA(lpMsg: &MSG, hWnd: &void, wMsgFilterMin: u32, wMsgFilterMax: u32)
fn TranslateMessage(lpMsg: &MSG)
fn DispatchMessageA(lpMsg: &MSG)
fn PostQuitMessage(nExitCode: i32)
fn BeginPaint(hWnd: &void, lpPaint: &PAINTSTRUCT)
fn EndPaint(hWnd: &void, lpPaint: &PAINTSTRUCT)
fn GetDC(hWnd: &void)
fn ReleaseDC(hWnd: &void, hDC: &void)
fn LoadCursorA(hInstance: &void, lpCursorName: &i8)
fn LoadIconA(hInstance: &void, lpIconName: &i8)
fn LoadImageA(hInst: &void, name: &i8, type: u32, cx: i32, cy: i32, fuLoad: u32)
fn GetClientRect(hWnd: &void, lpRect: &RECT)
fn InvalidateRect(hWnd: &void, lpRect: &RECT, bErase: i32)
fn RegisterClassExA(lpwcx: &WNDCLASSEXA)
