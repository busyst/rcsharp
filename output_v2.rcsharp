	path.data[path.len]  token_array[*index].symbol_id
	path.len  path.len  1
	*index  *index  1
	if *index  len  token_array[*index].token_type  TokenType::DoubleColon {
	if *index  1  len  token_array[*index  1].token_type  TokenType::Name {
	process::throw("Expected identifier after '::' in qualified type")
