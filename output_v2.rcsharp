fn is_expression_starter(token: TokenType){
	if token  TokenType::Name  token  TokenType::Integer  token  TokenType::Decimal  token  TokenType::String  token  TokenType::Char  token  TokenType::KeywordTrue  token  TokenType::KeywordFalse  token  TokenType::KeywordNull  token  TokenType::KeywordThis  token  TokenType::LParen  token  TokenType::LSquareBrace  token  TokenType::Dot {
	return true
