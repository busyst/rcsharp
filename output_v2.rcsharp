	return is_prefix_operator(token)
}
fn parse_body(token_array: &TokenData, token_len: u32, symbol_vector: &vector::Vec<string::String>, statement_vector: &vector::Vec<Stmt>){
	if token_len  0 {
	return
	}
	let len : u32 = token_len
	let tokens : &TokenData = token_array
	let index : u32 = 0
	while index  len{
	let token : TokenType = tokens[index].token_type
	if token  TokenType::KeywordReturn {
	index  index  1
	if tokens[index].token_type  TokenType::SemiColon {
	index  index  1
	let return_node : &ReturnNode = mem::malloc(size_of::<ReturnNode>()) as &ReturnNode
	return_node.has_value  false
	let stmt : Stmt = Stmt::{statement_type: StatementType::Return, node_ptr: return_node}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	let expr : Expression = parse_expression(tokens, &index, len)
	expect(tokens, &index, len, TokenType::SemiColon, "Expected ';' after return expression")
	let return_node : &ReturnNode = mem::malloc(size_of::<ReturnNode>()) as &ReturnNode
	return_node.has_value  true
	return_node.expression  expr
	let stmt : Stmt = Stmt::{statement_type: StatementType::Return, node_ptr: bitcast::<&void>(return_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordConst  token  TokenType::KeywordLet  token  TokenType::KeywordStatic {
	index  index  1
	let var_name : u16 = tokens[index].symbol_id
	expect(tokens, &index, len, TokenType::Name, "Expected variable name after variable declaration keyword")
	expect(tokens, &index, len, TokenType::Colon, "Expected ':' after variable deflaration to indicate type.")
	let type : Type = parse_type(tokens, &index, len)
	let has_value : bool = false
	let expr : Expression
	if tokens[index].token_type  TokenType::Equal {
	index  index  1
	let x : Expression = parse_expression(tokens, &index, len)
	expr  x
	has_value  true
	}
	expect(tokens, &index, len, TokenType::SemiColon, "Expected ';' at the end of variable declaration.")
	let declaration_node : &DeclarationNode = mem::malloc(size_of::<DeclarationNode>()) as &DeclarationNode
	declaration_node.name  var_name
	declaration_node.var_type  type
	declaration_node.has_value  has_value
	declaration_node.expression  expr
	declaration_node.var_comp_type  VarType::Stack
	if token  TokenType::KeywordConst {
	declaration_node.var_comp_type  VarType::Stack
	} else {
	if token  TokenType::KeywordStatic {
	declaration_node.var_comp_type  VarType::Static
	}
	}
	let stmt : Stmt = Stmt::{statement_type: StatementType::VarDec, node_ptr: bitcast::<&void>(declaration_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordBreak {
	index  index  1
	expect(tokens, &index, len, TokenType::SemiColon, "Expected ';' after break")
	let stmt : Stmt = Stmt::{statement_type: StatementType::Break, node_ptr: null}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordContinue {
	index  index  1
	expect(tokens, &index, len, TokenType::SemiColon, "Expected ';' after continue")
	let stmt : Stmt = Stmt::{statement_type: StatementType::Continue, node_ptr: null}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordIf {
	index  index  1
	let expression : Expression = parse_expression(tokens, &index, len)
	if tokens[index].token_type  TokenType::LBrace {
	process::throw("Expected '{' as the begining of if body.")
	}
	let then_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let then_len : u32 = index  1  then_start
	let then_body : vector::Vec<Stmt> = vector::new::<Stmt>()
	parse_body(tokens  then_start, then_len, symbol_vector, &then_body)
	let else_body : vector::Vec<Stmt> = vector::new::<Stmt>()
	if index  len  tokens[index].token_type  TokenType::KeywordElse {
	index  index  1
	if index  len  tokens[index].token_type  TokenType::KeywordIf {
	let else_if_start : u32 = index
	let tmp_index : u32 = index
	skip_if_statement(tokens, &tmp_index, len)
	let else_if_len : u32 = tmp_index  else_if_start
	parse_body(tokens  else_if_start, else_if_len, symbol_vector, &else_body)
	index  tmp_index
	} else {
	if tokens[index].token_type  TokenType::LBrace {
	process::throw("Expected '{' after else")
	}
	let else_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let else_len : u32 = index  1  else_start
	parse_body(tokens  else_start, else_len, symbol_vector, &else_body)
	}
	}
	let if_stmt : &IfStmt = mem::malloc(size_of::<IfStmt>()) as &IfStmt
	if_stmt.cond  expression
	if_stmt.then_body  then_body
	if_stmt.else_body  else_body
	let stmt : Stmt = Stmt::{statement_type: StatementType::If, node_ptr: bitcast::<&void>(if_stmt)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordWhile {
	index  index  1
	let expression : Expression = parse_expression(tokens, &index, len)
	if tokens[index].token_type  TokenType::LBrace {
	process::throw("Expected '{' as the begining of while body.")
	}
	let body_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let body_len : u32 = index  1  body_start
	let body : vector::Vec<Stmt> = vector::new::<Stmt>()
	parse_body(tokens  body_start, body_len, symbol_vector, &body)
	let while_stmt : &WhileStmt = mem::malloc(size_of::<WhileStmt>()) as &WhileStmt
	while_stmt.cond  expression
	while_stmt.body  body
	let stmt : Stmt = Stmt::{statement_type: StatementType::WhileLoop, node_ptr: bitcast::<&void>(while_stmt)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordLoop {
	index  index  1
	if tokens[index].token_type  TokenType::LBrace {
	process::throw("Expected '{' as the begining of while body.")
	}
	let body_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let body_len : u32 = index  1  body_start
	let body : vector::Vec<Stmt> = vector::new::<Stmt>()
	parse_body(tokens  body_start, body_len, symbol_vector, &body)
	let loop_stmt : &LoopStmt = mem::malloc(size_of::<LoopStmt>()) as &LoopStmt
	loop_stmt.body  body
	let stmt : Stmt = Stmt::{statement_type: StatementType::Loop, node_ptr: bitcast::<&void>(loop_stmt)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordDo {
	index  index  1
	if tokens[index].token_type  TokenType::LBrace {
	process::throw("Expected '{' as the begining of while body.")
	}
	let body_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let body_len : u32 = index  1  body_start
	let body : vector::Vec<Stmt> = vector::new::<Stmt>()
	parse_body(tokens  body_start, body_len, symbol_vector, &body)
	expect(tokens, &index, len, TokenType::KeywordWhile, "Expected while after do block.")
	let expression : Expression = parse_expression(tokens, &index, len)
	expect(tokens, &index, len, TokenType::SemiColon, "Expected semicolon after do {} while expression.")
	let do_stmt : &DoWhileStmt = mem::malloc(size_of::<DoWhileStmt>()) as &DoWhileStmt
	do_stmt.cond  expression
	do_stmt.body  body
	let stmt : Stmt = Stmt::{statement_type: StatementType::DoWhileLoop, node_ptr: bitcast::<&void>(do_stmt)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordFor {
	index  index  1
	let iter_expr : Expression = parse_expression(tokens, &index, len)
	expect(tokens, &index, len, TokenType::KeywordIn, "Expected in after name in for structure.")
	let in_expr : Expression = parse_expression(tokens, &index, len)
	if tokens[index].token_type  TokenType::LBrace {
	process::throw("Expected '{' as the begining of for body.")
	}
	let body_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let body_len : u32 = index  1  body_start
	let body : vector::Vec<Stmt> = vector::new::<Stmt>()
	parse_body(tokens  body_start, body_len, symbol_vector, &body)
	let for_stmt : &ForStmt = mem::malloc(size_of::<ForStmt>()) as &ForStmt
	for_stmt.iter  iter_expr
	for_stmt.in_expr  in_expr
	for_stmt.body  body
	let stmt : Stmt = Stmt::{statement_type: StatementType::ForLoop, node_ptr: bitcast::<&void>(for_stmt)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if is_expression_starter(token) {
	let expression : Expression = parse_expression(tokens, &index, len)
	expect(tokens, &index, len, TokenType::SemiColon, "Expected ';' at the end of expression.")
	let expr_node : &ExpressionNode = mem::malloc(size_of::<ExpressionNode>()) as &ExpressionNode
	expr_node.expression  expression
	let stmt : Stmt = Stmt::{statement_type: StatementType::Expression, node_ptr: bitcast::<&void>(expr_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	for i in 0 as u32..3{
	let q : string::String = token_type_to_string(&tokens[index  i], symbol_vector)
	console::write("---\t", 4)
	console::write_string(&q)
	console::write("\t---\n", 5)
	string::free(&q)
	}
	process::throw("todo!")
	}
}
fn get_flags(token_array: &TokenData, index: u32, mod_index: u32){
	if mod_index  NO_MODIFIER {
	return 0
	}
	let output : u8 = 0
	console::writeln("XXX", 3)
	for i in mod_index..index{
	if token_array[i].token_type  TokenType::KeywordPub {
	output  output  Flags::Public
	} else {
	if token_array[i].token_type  TokenType::KeywordExtern {
	output  output  Flags::External
	} else {
	if token_array[i].token_type  TokenType::KeywordInline {
	output  output  Flags::Inline
	} else {
	if token_array[i].token_type  TokenType::KeywordStatic {
	output  output  Flags::Static
	}
	}
	}
	}
	}
	console::println_i64(output as i64)
	return output
}
fn parse(token_array: &TokenData, token_len: u32, symbol_vector: &vector::Vec<string::String>, statement_vector: &vector::Vec<Stmt>){
	if token_len  0 {
	return
	}
	let index : u32 = 0
	let mod_index : u32 = NO_MODIFIER
	let len : u32 = token_len
	let tokens : &TokenData = token_array
	while index  len{
	let token : TokenType = tokens[index].token_type
	if is_modifier(token) {
	if mod_index  NO_MODIFIER {
	mod_index  index
	}
	index  index  1
		continue
	}
	if token  TokenType::Hint {
	mod_index  NO_MODIFIER
	index  index  1
	let is_bracket : bool = false
	if tokens[index].token_type  TokenType::LSquareBrace {
	is_bracket  true
	index  index  1
	}
	if tokens[index].token_type  TokenType::Name {
	process::throw("Expected name after hint symbol #")
	}
	let hint_name : u16 = tokens[index].symbol_id
	index  index  1
	let exprs : vector::Vec<Expression> = vector::new::<Expression>()
	if tokens[index].token_type  TokenType::LParen {
	index  index  1
	exprs  parse_expression_comma(tokens, &index, len)
	expect(tokens, &index, len, TokenType::RParen, "Expected ')' after arguments in hint")
	}
	let statement_type : StatementType = StatementType::CompilerHint
	if is_bracket {
	expect(tokens, &index, len, TokenType::RSquareBrace, "Expected ']' after arguments in attribute")
	statement_type  StatementType::Attribute
	}
	let hint_node : &HintNode = mem::malloc(size_of::<HintNode>()) as &HintNode
	hint_node.name  hint_name
	hint_node.expressions  exprs
	let stmt : Stmt = Stmt::{statement_type: statement_type, node_ptr: bitcast::<&void>(hint_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordFunction {
	let flags : u8 = get_flags(token_array, index, mod_index)
	mod_index  NO_MODIFIER
	index  index  1
	if tokens[index].token_type  TokenType::Name {
	process::throw("Expected function name after 'fn'")
	}
	let fn_name : u16 = tokens[index].symbol_id
	index  index  1
	if tokens[index].token_type  TokenType::LParen  tokens[index].token_type  TokenType::LogicLess {
	process::throw("Expected '(' or '<' after function name")
	}
	let generic : vector::Vec<u16> = vector::new::<u16>()
	if tokens[index].token_type  TokenType::LogicLess {
	index  index  1
	while tokens[index].token_type  TokenType::LogicGreater{
	if tokens[index].token_type  TokenType::Name {
	vector::push::<u16>(&generic, tokens[index].symbol_id)
	} else {
	process::throw("TODO ERROR")
	}
	if tokens[index].token_type  TokenType::Comma {
	index  index  1
	}
	index  index  1
	}
	index  index  1
	}
	index  index  1
	let args : vector::Vec<Argument> = parse_argument_comma(tokens, &index, len)
	if tokens[index].token_type  TokenType::RParen {
	process::throw("Expected ')' after function arguments")
	}
	index  index  1
	let ret_type : &Type = null
	if tokens[index].token_type  TokenType::Colon {
	index  index  1
	let parsed_type : Type = parse_type(tokens, &index, len)
	ret_type  mem::malloc(size_of::<Type>()) as &Type
	*ret_type  parsed_type
	}
	let nodes : vector::Vec<Stmt> = vector::new::<Stmt>()
	if tokens[index].token_type  TokenType::LBrace {
	let content_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let content_len : u32 = index  1  content_start
	parse_body(tokens  content_start, content_len, symbol_vector, &nodes)
	} else {
	if tokens[index].token_type  TokenType::FatArrow {
	index  index  1
	let expr_node : &ReturnNode = mem::malloc(size_of::<ReturnNode>()) as &ReturnNode
	expr_node.expression  parse_expression(tokens, &index, len)
	expect(tokens, &index, len, TokenType::SemiColon, "Expected ';' after expression function")
	let stmt : Stmt = Stmt::{statement_type: StatementType::Return, node_ptr: bitcast::<&void>(expr_node)}
	vector::push::<Stmt>(&nodes, stmt)
	} else {
	if tokens[index].token_type  TokenType::SemiColon {
	index  index  1
	}
	}
	}
	let fn_node : &FnNode = mem::malloc(size_of::<FnNode>()) as &FnNode
	fn_node.name  fn_name
	fn_node.arguments  args
	fn_node.return_type  ret_type
	fn_node.generic  generic
	fn_node.nodes  nodes
	fn_node.flags  flags
	let stmt : Stmt = Stmt::{statement_type: StatementType::Function, node_ptr: bitcast::<&void>(fn_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordNamespace {
	let flags : u8 = get_flags(token_array, index, mod_index)
	mod_index  NO_MODIFIER
	index  index  1
	if tokens[index].token_type  TokenType::Name {
	process::throw("Expected namespace name")
	}
	let namespace_name : u16 = tokens[index].symbol_id
	index  index  1
	let nodes : vector::Vec<Stmt> = vector::new::<Stmt>()
	if tokens[index].token_type  TokenType::LBrace {
	let content_start : u32 = index  1
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let content_len : u32 = index  1  content_start
	parse(tokens  content_start, content_len, symbol_vector, &nodes)
	} else {
	process::throw("Expected namespace body after namespace")
	}
	let namespace_node : &NamespaceNode = mem::malloc(size_of::<NamespaceNode>()) as &NamespaceNode
	namespace_node.name  namespace_name
	namespace_node.nodes  nodes
	let stmt : Stmt = Stmt::{statement_type: StatementType::Namespace, node_ptr: bitcast::<&void>(namespace_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordEnum {
	let flags : u8 = get_flags(token_array, index, mod_index)
	mod_index  NO_MODIFIER
	index  index  1
	if tokens[index].token_type  TokenType::Name {
	process::throw("Expected enum name")
	}
	let enum_name : u16 = tokens[index].symbol_id
	index  index  1
	let enum_type : &Type = null
	if tokens[index].token_type  TokenType::Colon {
	index  index  1
	let parsed_type : Type = parse_type(tokens, &index, len)
	enum_type  mem::malloc(size_of::<Type>()) as &Type
	*enum_type  parsed_type
	}
	let fields : vector::Vec<EnumField> = vector::new::<EnumField>()
	if tokens[index].token_type  TokenType::LBrace {
	fields  parse_enum_fields(tokens, &index, len)
	} else {
	process::throw("Expected '{' for enum body")
	}
	let enum_node : &EnumNode = mem::malloc(size_of::<EnumNode>()) as &EnumNode
	enum_node.name  enum_name
	enum_node.enum_type  enum_type
	enum_node.fields  fields
	enum_node.flags  flags
	let stmt : Stmt = Stmt::{statement_type: StatementType::Enum, node_ptr: bitcast::<&void>(enum_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if token  TokenType::KeywordStruct {
	let flags : u8 = get_flags(token_array, index, mod_index)
	mod_index  NO_MODIFIER
	index  index  1
	if tokens[index].token_type  TokenType::Name {
	process::throw("Expected struct name")
	}
	let struct_name : u16 = tokens[index].symbol_id
	index  index  1
	let generics : vector::Vec<u16> = vector::new::<u16>()
	if tokens[index].token_type  TokenType::LogicLess {
	generics  parse_generic_params(tokens, &index, len)
	}
	let fields : vector::Vec<Argument> = vector::new::<Argument>()
	if tokens[index].token_type  TokenType::LBrace {
	fields  parse_struct_fields(tokens, &index, len)
	} else {
	process::throw("Expected '{' for struct body")
	}
	let struct_node : &StructNode = mem::malloc(size_of::<StructNode>()) as &StructNode
	struct_node.name  struct_name
	struct_node.fields  fields
	struct_node.generic  generics
	struct_node.flags  flags
	let stmt : Stmt = Stmt::{statement_type: StatementType::Struct, node_ptr: bitcast::<&void>(struct_node)}
	vector::push::<Stmt>(statement_vector, stmt)
		continue
	}
	if tokens[index].token_type  TokenType::LBrace {
	let flags : u8 = get_flags(token_array, index, mod_index)
	mod_index  NO_MODIFIER
	let start : u32 = index
	skip_nested(tokens, &index, len, TokenType::LBrace, TokenType::RBrace)
	let m : vector::Vec<Stmt> = vector::new::<Stmt>()
	let inner_len : u32 = index  1  start  1
	parse(tokens  start  1, inner_len, symbol_vector, &m)
	for i in 0 as u32..m.length{
	if m.array[i].statement_type  StatementType::Struct {
	let s : &StructNode = m.array[i].node_ptr as &StructNode
	s.flags  s.flags  flags
	} else {
	if m.array[i].statement_type  StatementType::Function {
	let f : &FnNode = m.array[i].node_ptr as &FnNode
	f.flags  f.flags  flags
	} else {
	if m.array[i].statement_type  StatementType::Enum {
	let e : &EnumNode = m.array[i].node_ptr as &EnumNode
	e.flags  e.flags  flags
	}
	}
	}
	vector::push::<Stmt>(statement_vector, m.array[i])
	}
		continue
	}
	if mod_index  NO_MODIFIER {
	if tokens[index  1].token_type  TokenType::KeywordConst  tokens[index  1].token_type  TokenType::KeywordStatic {
	if tokens[index].token_type  TokenType::Name {
	process::throw("Expected this be a constant or static declaration")
	}
	let var_name : u16 = tokens[index].symbol_id
	index  index  1
	let ret_type : &Type
	if tokens[index].token_type  TokenType::Colon {
	index  index  1
	let parsed_type : Type = parse_type(tokens, &index, len)
	ret_type  mem::malloc(size_of::<Type>()) as &Type
	*ret_type  parsed_type
	} else {
	process::throw("Expected Colon and Type")
	}
	if tokens[index].token_type  TokenType::Equal {
	index  index  1
	parse_expression(tokens, &index, len)
	} else {
	if tokens[index].token_type  TokenType::SemiColon {
	} else {
	process::throw("Expected SemiColon or expression")
	}
	}
	if tokens[index].token_type  TokenType::SemiColon {
	process::throw("Expected SemiColon")
	}
	index  index  1
	mod_index  NO_MODIFIER
		continue
	}
	}
	for i in 0 as u32..3{
	let q : string::String = token_type_to_string(&tokens[index  i], null)
	console::write_string(&q)
	console::write("@@@@\n", 5)
	string::free(&q)
	}
	process::throw("--UNEXPECTED TOKEN--")
	}
}
fn rcsharp_compile(input_file_path: &i8, output_file_path: &i8){
	let buffer : &i8 = stalloc::<i8>(255)
	let file_name_start : &i8
	let len : i32 = fs::GetFullPathNameA(input_file_path, 255, buffer, bitcast::<&i8>(&file_name_start))
	let env_path_len : i32 = bitcast::<usize>(file_name_start)  bitcast::<usize>(buffer) as i32
	console::println_i64(env_path_len as i64)
	let ilen : i32 = string_utils::c_str_len(input_file_path)
	let olen : i32 = string_utils::c_str_len(output_file_path)
	let base_env : string::String = string::from_data(buffer, env_path_len)
	console::write_string(&base_env)
	let file_stack : vector::Vec<string::String> = vector::new::<string::String>()
	vector::push::<string::String>(&file_stack, string::from_c_string(input_file_path))
	console::writeln("Loading...", 10)
	let main_statement_vector : vector::Vec<Stmt> = vector::new::<Stmt>()
	let symbol_vector : vector::Vec<string::String> = vector::new::<string::String>()
	let file_index : u32 = 0
	while file_index  file_stack.length{
	console::writeln("Reading File...", 15)
	console::write_string(&file_stack.array[file_index])
	console::write("\n", 1)
	let file_data : string::String = fs::read_full_file_as_string(file_stack.array[file_index].data)
	let token_vector : vector::Vec<TokenData> = vector::new::<TokenData>()
	lex(&file_data, &token_vector, &symbol_vector)
	string::free(&file_data)
	let statement_vector : vector::Vec<Stmt> = vector::new::<Stmt>()
	parse(token_vector.array, token_vector.length, &symbol_vector, &statement_vector)
	for idx in 0 as u32..statement_vector.length{
	let stmt : &Stmt = &statement_vector.array[idx]
	if stmt.statement_type  StatementType::CompilerHint {
	let node : &HintNode = stmt.node_ptr as &HintNode
	let sym_array : &string::String = symbol_vector.array
	if sym_array[node.name].len  7  mem::compare(sym_array[node.name].data, "include", 7)  0 {
	if node.expressions.length  1 {
	process::throw("include directive must have only one path")
	}
	let expr : &Expression = &node.expressions.array[0]
	if expr.type  ExpressionType::StringConst {
	process::throw("include directive must have only one path")
	}
	let str_expr : &StringConstExpr = expr.val as &StringConstExpr
	console::write("\t", 1)
	console::write_string(&sym_array[str_expr.idx])
	console::write("\n\r", 2)
	let found : bool = false
	for i in 0 as u32..file_stack.length{
	if string::equal(&sym_array[str_expr.idx], &file_stack.array[i]) {
	found  true
		break
	}
	}
	if !found {
	vector::push::<string::String>(&file_stack, string::clone(&sym_array[str_expr.idx]))
	}
		continue
	} else {
	process::throw("Unrecognized directive")
	}
	}
	vector::push::<Stmt>(&main_statement_vector, *stmt)
	}
	vector::free::<Stmt>(&statement_vector)
	file_index  file_index  1
	}
	console::writeln("Loaded...", 9)
	console::writeln("Project Files...", 16)
	console::write("Sym Vec Len: ", 13)
	console::println_u64(symbol_vector.length as u64)
	for i in 0 as u32..file_stack.length{
	console::write("\t", 1)
	console::write_string(&file_stack.array[i])
	console::write("\n", 1)
	}
	console::println_i64(main_statement_vector.length as i64)
	console::writeln("Compiling...", 12)
	let stdout : string::String = string::empty()
	compile(&main_statement_vector, &symbol_vector, &stdout)
	fs::write_to_file(output_file_path, stdout.data, stdout.len as u32)
	process::ExitProcess(0)
}
fn debug_dump_type(expr: &Type, symbol_vector: &vector::Vec<string::String>, stdout: &string::String){
	let sym_array : &string::String = symbol_vector.array
	if expr.type  TypeType::Named {
	let node : &NamedType = expr.val as &NamedType
	string::append_str(stdout, sym_array[node.idx].data, sym_array[node.idx].len)
	} else {
	if expr.type  TypeType::Pointer {
	let node : &PointerType = expr.val as &PointerType
	let inner : &Type = &node.inner as &Type
	for i in 0 as u8..node.deep{
	string::append(stdout, '')
	}
	debug_dump_type(inner, symbol_vector, stdout)
	} else {
	if expr.type  TypeType::Function {
	let node : &FunctionType = expr.val as &FunctionType
	string::append_str(stdout, "fn(", 3)
	for i in 0 as u32..node.args.length{
	debug_dump_type(&node.args.array[i], symbol_vector, stdout)
	if i  node.args.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append_str(stdout, ") : ", 4)
	debug_dump_type(&node.return_type, symbol_vector, stdout)
	} else {
	if expr.type  TypeType::NamespaceLink {
	let node : &NamespaceLinkType = expr.val as &NamespaceLinkType
	for i in 0 as u8..node.path.len{
	string::append_str(stdout, sym_array[node.path.data[i]].data, sym_array[node.path.data[i]].len)
	string::append_str(stdout, "::", 2)
	}
	let inner : &Type = &node.rval as &Type
	debug_dump_type(inner, symbol_vector, stdout)
	} else {
	if expr.type  TypeType::Generic {
	let node : &GenericType = expr.val as &GenericType
	string::append_str(stdout, sym_array[node.idx].data, sym_array[node.idx].len)
	string::append(stdout, '')
	for i in 0 as u32..node.gen_args.length{
	debug_dump_type(&node.gen_args.array[i], symbol_vector, stdout)
	if i  node.gen_args.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	} else {
	if expr.type  TypeType::ConstantSizeArray {
	let node : &ConstantSizeArrayType = expr.val as &ConstantSizeArrayType
	string::append(stdout, '')
	debug_dump_type(&node.inner, symbol_vector, stdout)
	string::append_str(stdout, "; ", 2)
	debug_dump_expression(&node.size, symbol_vector, stdout)
	string::append(stdout, '')
	}
	}
	}
	}
	}
	}
}
fn debug_dump_expression(expr: &Expression, symbol_vector: &vector::Vec<string::String>, stdout: &string::String){
	if expr.type  ExpressionType::Integer  expr.type  ExpressionType::Decimal  expr.type  ExpressionType::Name {
	let data : &IntegerExpr = expr.val as &IntegerExpr
	string::append_str(stdout, symbol_vector.array[data.idx].data, symbol_vector.array[data.idx].len)
	return
	}
	if expr.type  ExpressionType::Char {
	let data : &CharExpr = expr.val as &CharExpr
	string::append(stdout, '\'')
	if data.val  '\\' {
	string::append(stdout, '\\')
	string::append(stdout, '\\')
	} else {
	if data.val  '\'' {
	string::append(stdout, '\\')
	string::append(stdout, '\'')
	}
	}
	string::append(stdout, '\'')
	return
	}
	if expr.type  ExpressionType::NullPtr {
	string::append_str(stdout, "null", 4)
	return
	}
	if expr.type  ExpressionType::StringConst {
	let data : &StringConstExpr = expr.val as &StringConstExpr
	string::append(stdout, '')
	string::append_str(stdout, symbol_vector.array[data.idx].data, symbol_vector.array[data.idx].len)
	string::append(stdout, '')
	return
	}
	if expr.type  ExpressionType::Call {
	let data : &CallExpr = expr.val as &CallExpr
	debug_dump_expression(&data.lval, symbol_vector, stdout)
	if data.generics.length  0 {
	string::append(stdout, '')
	string::append(stdout, '')
	string::append(stdout, '')
	for i in 0 as u32..data.generics.length{
	debug_dump_type(&data.generics.array[i], symbol_vector, stdout)
	if i  data.generics.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	}
	string::append(stdout, '')
	for i in 0 as u32..data.expr.length{
	debug_dump_expression(&data.expr.array[i], symbol_vector, stdout)
	if i  data.expr.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	return
	}
	if expr.type  ExpressionType::StaticAccess {
	let data : &StaticAccessExpr = expr.val as &StaticAccessExpr
	debug_dump_expression(&data.rval, symbol_vector, stdout)
	string::append_str(stdout, "::", 2)
	string::append_str(stdout, symbol_vector.array[data.member].data, symbol_vector.array[data.member].len)
	return
	}
	if expr.type  ExpressionType::MemberAccess {
	let data : &MemberAccessExpr = expr.val as &MemberAccessExpr
	debug_dump_expression(&data.rval, symbol_vector, stdout)
	string::append(stdout, '')
	string::append_str(stdout, symbol_vector.array[data.member].data, symbol_vector.array[data.member].len)
	return
	}
	if expr.type  ExpressionType::Cast {
	let data : &CastExpr = expr.val as &CastExpr
	debug_dump_expression(&data.rval, symbol_vector, stdout)
	string::append_str(stdout, " as ", 4)
	debug_dump_type(&data.to, symbol_vector, stdout)
	return
	}
	if expr.type  ExpressionType::Boolean {
	let data : &BoolExpr = expr.val as &BoolExpr
	if data.val {
	string::append_str(stdout, "true", 4)
	} else {
	string::append_str(stdout, "false", 5)
	}
	return
	}
	if expr.type  ExpressionType::BinaryOp {
	let data : &BinaryOpExpr = expr.val as &BinaryOpExpr
	debug_dump_expression(&data.lval, symbol_vector, stdout)
	string::append(stdout, '')
	string::append(stdout, '')
	debug_dump_expression(&data.rval, symbol_vector, stdout)
	return
	}
	if expr.type  ExpressionType::UnaryOp {
	let data : &UnaryOpExpr = expr.val as &UnaryOpExpr
	if data.op  UnaryOp::Negate {
	string::append(stdout, '')
	} else {
	if data.op  UnaryOp::Not {
	string::append(stdout, '')
	} else {
	if data.op  UnaryOp::Deref {
	string::append(stdout, '')
	} else {
	if data.op  UnaryOp::Pointer {
	string::append(stdout, '')
	} else {
	if data.op  UnaryOp::BitFlip {
	string::append(stdout, '')
	}
	}
	}
	}
	}
	debug_dump_expression(&data.rval, symbol_vector, stdout)
	return
	}
	if expr.type  ExpressionType::Range {
	let data : &RangeExpr = expr.val as &RangeExpr
	debug_dump_expression(&data.start, symbol_vector, stdout)
	string::append_str(stdout, "..", 2)
	if data.inclusive {
	string::append(stdout, '')
	}
	debug_dump_expression(&data.end, symbol_vector, stdout)
	return
	}
	if expr.type  ExpressionType::Index {
	let data : &IndexExpr = expr.val as &IndexExpr
	debug_dump_expression(&data.lval, symbol_vector, stdout)
	string::append(stdout, '')
	debug_dump_expression(&data.index_expr, symbol_vector, stdout)
	string::append(stdout, '')
	return
	}
	if expr.type  ExpressionType::NameWithGenerics {
	let data : &NameWithGenericsExpr = expr.val as &NameWithGenericsExpr
	debug_dump_expression(&data.rval, symbol_vector, stdout)
	string::append(stdout, '')
	string::append(stdout, '')
	string::append(stdout, '')
	for i in 0 as u32..data.generics.length{
	debug_dump_type(&data.generics.array[i], symbol_vector, stdout)
	if i  data.generics.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	return
	}
	if expr.type  ExpressionType::StructInit {
	let data : &StructInitExpr = expr.val as &StructInitExpr
	debug_dump_expression(&data.type, symbol_vector, stdout)
	string::append(stdout, '')
	string::append(stdout, '')
	string::append(stdout, '')
	for i in 0 as u32..data.expr.length{
	string::append_str(stdout, symbol_vector.array[data.expr.array[i].name].data, symbol_vector.array[data.expr.array[i].name].len)
	string::append_str(stdout, ": ", 2)
	debug_dump_expression(&data.expr.array[i].expr, symbol_vector, stdout)
	if i  data.expr.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	return
	}
	console::println_i64(expr.type as i64)
}
fn compile_body(statement_vector: &vector::Vec<Stmt>, symbol_vector: &vector::Vec<string::String>, stdout: &string::String){
	let index : u32 = 0
	let len : u32 = statement_vector.length
	let sym_array : &string::String = symbol_vector.array
	while index  len{
	let statement : &Stmt = &statement_vector.array[index]
	if statement.statement_type  StatementType::VarDec {
	let node : &DeclarationNode = statement.node_ptr as &DeclarationNode
	if node.var_comp_type  VarType::Constant {
	string::append_str(stdout, "\tconst ", 7)
	} else {
	if node.var_comp_type  VarType::Static {
	string::append_str(stdout, "\tstatic ", 8)
	} else {
	if node.var_comp_type  VarType::Stack {
	string::append_str(stdout, "\tlet ", 5)
	}
	}
	}
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append_str(stdout, " : ", 3)
	debug_dump_type(&node.var_type, symbol_vector, stdout)
	if node.has_value {
	string::append_str(stdout, " = ", 3)
	debug_dump_expression(&node.expression, symbol_vector, stdout)
	}
	string::append(stdout, '')
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Expression {
	let node : &ExpressionNode = statement.node_ptr as &ExpressionNode
	string::append_str(stdout, "\t", 1)
	debug_dump_expression(&node.expression, symbol_vector, stdout)
	string::append(stdout, '')
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Return {
	let node : &ReturnNode = statement.node_ptr as &ReturnNode
	string::append_str(stdout, "\treturn ", 7)
	if node.has_value {
	string::append(stdout, '')
	debug_dump_expression(&node.expression, symbol_vector, stdout)
	}
	string::append(stdout, '')
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::If {
	let node : &IfStmt = statement.node_ptr as &IfStmt
	string::append_str(stdout, "\tif ", 4)
	debug_dump_expression(&node.cond, symbol_vector, stdout)
	string::append_str(stdout, " {\n", 3)
	compile_body(&node.then_body, symbol_vector, stdout)
	if node.else_body.length  0 {
	string::append_str(stdout, "\t} else {\n", 10)
	compile_body(&node.else_body, symbol_vector, stdout)
	string::append_str(stdout, "\t}\n", 3)
	} else {
	string::append_str(stdout, "\t}\n", 3)
	}
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Loop {
	let node : &LoopStmt = statement.node_ptr as &LoopStmt
	string::append_str(stdout, "\tloop{\n", 7)
	compile_body(&node.body, symbol_vector, stdout)
	string::append_str(stdout, "\t}\n", 3)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::WhileLoop {
	let node : &WhileStmt = statement.node_ptr as &WhileStmt
	string::append_str(stdout, "\twhile ", 7)
	debug_dump_expression(&node.cond, symbol_vector, stdout)
	string::append_str(stdout, "{\n", 2)
	compile_body(&node.body, symbol_vector, stdout)
	string::append_str(stdout, "\t}\n", 3)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::ForLoop {
	let node : &ForStmt = statement.node_ptr as &ForStmt
	string::append_str(stdout, "\tfor ", 5)
	debug_dump_expression(&node.iter, symbol_vector, stdout)
	string::append_str(stdout, " in ", 4)
	debug_dump_expression(&node.in_expr, symbol_vector, stdout)
	string::append_str(stdout, "{\n", 2)
	compile_body(&node.body, symbol_vector, stdout)
	string::append_str(stdout, "\t}\n", 3)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::DoWhileLoop {
	let node : &DoWhileStmt = statement.node_ptr as &DoWhileStmt
	string::append_str(stdout, "\tdo{\n", 5)
	compile_body(&node.body, symbol_vector, stdout)
	string::append_str(stdout, "\t}while ", 8)
	debug_dump_expression(&node.cond, symbol_vector, stdout)
	string::append_str(stdout, ";\n", 2)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Continue {
	string::append_str(stdout, "\t\tcontinue\n", 11)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Break {
	string::append_str(stdout, "\t\tbreak\n", 8)
	index  index  1
		continue
	}
	}
	}
	}
	}
	}
	}
	}
	}
	}
	for i in 0 as u32..3{
	console::println_i64(statement_vector.array[index  i].statement_type as i64)
	console::write("@@@@\n\r", 6)
	}
	process::throw("--UNEXPECTED STATEMENT-- BDOY")
	}
}
fn compile_internal(path: Path, statement_vector: &vector::Vec<Stmt>, symbol_vector: &vector::Vec<string::String>, stdout: &string::String){
	let index : u32 = 0
	let len : u32 = statement_vector.length
	let sym_array : &string::String = symbol_vector.array
	let enums : vector::Vec<u64> = vector::new::<u64>()
	let structs : vector::Vec<u64> = vector::new::<u64>()
	let functions : vector::Vec<u64> = vector::new::<u64>()
	let declarations : vector::Vec<u64> = vector::new::<u64>()
	while index  len{
	let statement : &Stmt = &statement_vector.array[index]
	if statement.statement_type  StatementType::CompilerHint {
	process::throw("INCLUDE ALREADY HANDLED, OTHERS ARE NOT IMPLEMENTED")
	let node : &HintNode = statement.node_ptr as &HintNode
	string::append(stdout, '')
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append(stdout, '')
	for x in 0 as u32..node.expressions.length{
	let expr : &Expression = &node.expressions.array[x]
	debug_dump_expression(expr, symbol_vector, stdout)
	if x  node.expressions.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	string::append(stdout, '')
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Attribute {
	index  index  1
		continue
	let node : &HintNode = statement.node_ptr as &HintNode
	string::append_str(stdout, "#[", 2)
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append(stdout, '')
	for x in 0 as u32..node.expressions.length{
	let expr : &Expression = &node.expressions.array[x]
	debug_dump_expression(expr, symbol_vector, stdout)
	if x  node.expressions.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	string::append_str(stdout, "]\n", 2)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Function {
	let node : &FnNode = statement.node_ptr as &FnNode
	string::append_str(stdout, "fn ", 3)
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	if node.generic.length  0 {
	string::append(stdout, '')
	for x in 0 as u32..node.generic.length{
	string::append_str(stdout, sym_array[node.generic.array[x]].data, sym_array[node.generic.array[x]].len)
	if x  node.generic.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	}
	string::append(stdout, '')
	for x in 0 as u32..node.arguments.length{
	let arg : &Argument = &node.arguments.array[x]
	string::append_str(stdout, sym_array[arg.name].data, sym_array[arg.name].len)
	string::append_str(stdout, ": ", 2)
	debug_dump_type(&arg.type, symbol_vector, stdout)
	if x  node.arguments.length  1 {
	string::append_str(stdout, ", ", 2)
	}
	}
	string::append(stdout, '')
	if node.nodes.length  0 {
	string::append_str(stdout, "{\n", 2)
	compile_body(&node.nodes, symbol_vector, stdout)
	string::append(stdout, '')
	}
	string::append(stdout, '')
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Struct {
	index  index  1
		continue
	let node : &StructNode = statement.node_ptr as &StructNode
	string::append_str(stdout, "struct ", 7)
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append_str(stdout, "{\n", 2)
	for x in 0 as u32..node.fields.length{
	let node : &Argument = &node.fields.array[x]
	string::append_str(stdout, "\t", 1)
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append_str(stdout, ": ", 2)
	debug_dump_type(&node.type, symbol_vector, stdout)
	string::append(stdout, '')
	}
	string::append_str(stdout, "}\n", 2)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Enum {
	let node : &EnumNode = statement.node_ptr as &EnumNode
	let q : u32 = 0
	while statement_vector.array[index  q  1].statement_type  StatementType::Attribute{
	q  q  1
	}
	let packed : u64 = 0
	packed  index as u64  32
	packed  packed  q as u64
	vector::push::<u64>(&enums, packed)
	string::append_str(stdout, "enum ", 5)
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append_str(stdout, "{\n", 2)
	for x in 0 as u32..node.fields.length{
	let node : &EnumField = &node.fields.array[x]
	string::append_str(stdout, "\t", 1)
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	if node.has_value {
	string::append_str(stdout, ": ", 2)
	debug_dump_expression(&node.value, symbol_vector, stdout)
	}
	string::append(stdout, '')
	}
	string::append_str(stdout, "}\n", 2)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::Namespace {
	let node : &NamespaceNode = statement.node_ptr as &NamespaceNode
	let path : Path = path
	if path.len  8 {
	process::throw("Nested namespaces too deep")
	}
	path.data[path.len]  node.name
	path.len  path.len  1
	compile_internal(path, &node.nodes, symbol_vector, stdout)
	index  index  1
		continue
	} else {
	if statement.statement_type  StatementType::VarDec {
	let node : &DeclarationNode = statement.node_ptr as &DeclarationNode
	if node.var_comp_type  VarType::Constant {
	string::append_str(stdout, "const ", 7)
	} else {
	if node.var_comp_type  VarType::Static {
	string::append_str(stdout, "static ", 8)
	} else {
	if node.var_comp_type  VarType::Stack {
	process::throw("let is not allowed in top scope")
	}
	}
	}
	string::append_str(stdout, sym_array[node.name].data, sym_array[node.name].len)
	string::append_str(stdout, " : ", 3)
	debug_dump_type(&node.var_type, symbol_vector, stdout)
	if node.has_value {
	string::append_str(stdout, " = ", 3)
	debug_dump_expression(&node.expression, symbol_vector, stdout)
	}
	string::append(stdout, '')
	index  index  1
		continue
	}
	}
	}
	}
	}
	}
	}
	for i in 0 as u32..3{
	console::println_i64(statement_vector.array[index  i].statement_type as i64)
	console::write("@@@@\n\r", 6)
	}
	process::throw("--UNEXPECTED STATEMENT--")
	}
}
fn compile(statement_vector: &vector::Vec<Stmt>, symbol_vector: &vector::Vec<string::String>, stdout: &string::String){
	FILL_STATIC_PRIMITIVE_TYPES_INFO()
	let path : Path
	path.len  0
	compile_internal(path, statement_vector, symbol_vector, stdout)
}
fn invalid_layout(){
	let x : Layout
	x.size  65535
	x.align  65535
	return x
}
fn zero_layout(){
	let x : Layout
	x.size  0
	x.align  1
	return x
}
fn one_layout(){
	let x : Layout
	x.size  1
	x.align  1
	return x
}
fn two_layout(){
	let x : Layout
	x.size  2
	x.align  2
	return x
}
fn four_layout(){
	let x : Layout
	x.size  4
	x.align  4
	return x
}
fn eight_layout(){
	let x : Layout
	x.size  8
	x.align  8
	return x
}
enum PrimitiveKind{
	Void
	Bool
	SignedInt
	UnsignedInt
	Decimal
}
fn FILL_STATIC_PRIMITIVE_TYPES_INFO(){
	POINTER_LAYOUT  eight_layout()
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "void", llvm_signature: "void", layout: zero_layout(), kind: PrimitiveKind::Void}
	PRIMITIVE_TYPES_INFO[0]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "bool", llvm_signature: "i1", layout: one_layout(), kind: PrimitiveKind::Bool}
	PRIMITIVE_TYPES_INFO[1]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "i8", llvm_signature: "i8", layout: one_layout(), kind: PrimitiveKind::SignedInt}
	PRIMITIVE_TYPES_INFO[2]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "i16", llvm_signature: "i16", layout: two_layout(), kind: PrimitiveKind::SignedInt}
	PRIMITIVE_TYPES_INFO[3]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "i32", llvm_signature: "i32", layout: four_layout(), kind: PrimitiveKind::SignedInt}
	PRIMITIVE_TYPES_INFO[4]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "i64", llvm_signature: "i64", layout: eight_layout(), kind: PrimitiveKind::SignedInt}
	PRIMITIVE_TYPES_INFO[5]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "isize", llvm_signature: "i64", layout: eight_layout(), kind: PrimitiveKind::SignedInt}
	PRIMITIVE_TYPES_INFO[6]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "u8", llvm_signature: "i8", layout: one_layout(), kind: PrimitiveKind::UnsignedInt}
	PRIMITIVE_TYPES_INFO[7]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "u16", llvm_signature: "i16", layout: two_layout(), kind: PrimitiveKind::UnsignedInt}
	PRIMITIVE_TYPES_INFO[8]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "u32", llvm_signature: "i32", layout: four_layout(), kind: PrimitiveKind::UnsignedInt}
	PRIMITIVE_TYPES_INFO[9]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "u64", llvm_signature: "i64", layout: eight_layout(), kind: PrimitiveKind::UnsignedInt}
	PRIMITIVE_TYPES_INFO[10]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "usize", llvm_signature: "i64", layout: eight_layout(), kind: PrimitiveKind::UnsignedInt}
	PRIMITIVE_TYPES_INFO[11]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "f16", llvm_signature: "half", layout: two_layout(), kind: PrimitiveKind::Decimal}
	PRIMITIVE_TYPES_INFO[12]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "f32", llvm_signature: "float", layout: four_layout(), kind: PrimitiveKind::Decimal}
	PRIMITIVE_TYPES_INFO[13]  x
	let x : PrimitiveTypeInfo = PrimitiveTypeInfo::{name: "f64", llvm_signature: "double", layout: eight_layout(), kind: PrimitiveKind::Decimal}
	PRIMITIVE_TYPES_INFO[14]  x
}
fn find_primitive_type(name: &i8, len: i32){
	if len  4 {
	if mem::equal(name, "void", 4)  0 {
	return 0
	}
	if mem::equal(name, "bool", 4)  0 {
	return 1
	}
	}
	return -1
}
